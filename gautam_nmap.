    if [[ "$confirm" =~ ^[Yy]$ ]]; then
        rm -rf "$RESULTS_DIR"/*
        rm -rf "$REPORTS_DIR"/*
        echo -e "${G}[✓] All results and reports deleted!${NC}"
        log_message "All results and reports deleted"
    else
        echo -e "${Y}[!] Cancelled${NC}"
    fi
    sleep 1
}

