        sleep 1
        return
    fi
    
    echo -e "${Y}═══════════════════════════════════════════${NC}"
    echo -e "${B}🎯 TARGET INFORMATION${NC}"
    echo -e "${Y}═══════════════════════════════════════════${NC}"
    echo -e "${W}Target: ${G}$CURRENT_TARGET${NC}"
    echo ""
    
    IP=$(dig +short $CURRENT_TARGET 2>/dev/null | head -1)
