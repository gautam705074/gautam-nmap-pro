check_nmap() {
    echo -e "${Y}[*] Checking Nmap installation...${NC}"
    log_message "Checking Nmap installation"
    if ! command -v nmap &> /dev/null; then
        echo -e "${Y}[!] Nmap not found. Installing...${NC}"
        sudo apt update -q 2>/dev/null
        sudo apt install nmap -y -q 2>/dev/null
        echo -e "${G}[✓] Nmap installed successfully!${NC}"
        log_message "Nmap installed"
    else
        echo -e "${G}[✓] Nmap is installed!${NC}"
    fi
    sleep 1
}

