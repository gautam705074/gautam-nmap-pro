set_target() {
    echo -e "${Y}═══════════════════════════════════════════${NC}"
    echo -e "${B}🎯 CHANGE TARGET${NC}"
    echo -e "${Y}═══════════════════════════════════════════${NC}"
    echo -e "${W}Current Target: ${G}$CURRENT_TARGET${NC}"
    if [ ! -z "$CURRENT_TARGET" ]; then
        IP=$(dig +short $CURRENT_TARGET 2>/dev/null | head -1)
        echo -e "${W}Current IP: ${G}${IP:-N/A}${NC}"
    fi
    echo ""
    echo -e "${Y}📌 Examples:${NC}"
    echo -e "${W}  - Domain: ${G}google.com${NC}"
    echo -e "${W}  - IP: ${G}192.168.1.1${NC}"
    echo -e "${W}  - Range: ${G}192.168.1.0/24${NC}"
    echo ""
    read -p "$(echo -e ${G}"Enter new target: "${NC})" new_target
    
    if [ -z "$new_target" ]; then
        echo -e "${R}[!] Target cannot be empty!${NC}"
        sleep 1
        return
    fi
    
    CURRENT_TARGET="$new_target"
    echo -e "${G}═══════════════════════════════════════════${NC}"
    echo -e "${G}[✓] Target changed successfully!${NC}"
    echo -e "${G}[✓] New Target: ${W}$CURRENT_TARGET${NC}"
    log_message "Target changed to: $CURRENT_TARGET"
    
    IP=$(dig +short $CURRENT_TARGET 2>/dev/null | head -1)
    if [ ! -z "$IP" ]; then
        echo -e "${G}[✓] IP Address: ${W}$IP${NC}"
    fi
    
    if ping -c 1 -W 2 $CURRENT_TARGET &> /dev/null 2>&1; then
        echo -e "${G}[✓] Host is ${W}ALIVE 🟢${NC}"
    else
        echo -e "${R}[✗] Host is ${W}DOWN 🔴${NC}"
    fi
    echo -e "${G}═══════════════════════════════════════════${NC}"
    sleep 2
}

run_scan() {
    local target=$1
    local scan_name=$2
    local nmap_command=$3
    
    echo -e "${C}[+] $scan_name${NC}"
    log_message "Starting $scan_name on $target"
    
    local scan_file="$RESULTS_DIR/${scan_name}_${target}_${TIMESTAMP}.txt"
    
    echo -e "${Y}[*] Running scan...${NC}"
    eval "$nmap_command" > "$scan_file" 2>&1
    
    if [ -s "$scan_file" ]; then
        echo -e "${G}[✓] Scan complete!${NC}"
        echo -e "${G}[✓] Results saved: $scan_file${NC}"
        log_message "$scan_name completed on $target"
        
        generate_html_report "$target" "$scan_name" "$scan_file"
        
        echo ""
        echo -e "${Y}===== OPEN PORTS =====${NC}"
        grep -E "^[0-9]" "$scan_file" | grep open | head -10 || echo "No open ports found"
        
        return 0
    else
        echo -e "${R}[✗] Scan failed!${NC}"
        log_message "$scan_name failed on $target"
        return 1
    fi
}

basic_ping() { run_scan "$1" "ping_scan" "nmap -sn $1"; }
common_ports() { run_scan "$1" "common_ports" "nmap -p 20,21,22,23,25,53,80,443,8080 -sV $1"; }
top_ports() { run_scan "$1" "top10_ports" "nmap --top-ports 10 -sV $1"; }
http_check() { run_scan "$1" "http_check" "nmap -p 80,443 --script http-headers,http-server-header $1"; }
service_version() { run_scan "$1" "service_version" "nmap -sV --version-intensity 7 --top-ports 20 $1"; }
os_detection() { run_scan "$1" "os_detection" "nmap -O $1"; }
script_scan() { run_scan "$1" "script_scan" "nmap -sC --top-ports 10 $1"; }

port_range() {
    echo -e "${C}[+] CUSTOM PORT RANGE SCAN${NC}"
    echo -e "${Y}[*] Enter port range (e.g., 1-1000 or 80,443,8080)${NC}"
    read -p "Ports: " ports
    if [ -z "$ports" ]; then
        echo -e "${R}[!] Ports cannot be empty!${NC}"
        return
    fi
    run_scan "$1" "port_range_$ports" "nmap -p $ports -sV $1"
}

vuln_scan() {
    target=$1
    echo -e "${C}[+] VULNERABILITY SCAN${NC}"
    echo -e "${Y}[*] Checking for known vulnerabilities...${NC}"
    log_message "Starting vulnerability scan on $target"
    
    local scan_file="$RESULTS_DIR/vuln_scan_${target}_${TIMESTAMP}.txt"
    
    echo -e "${Y}[*] Running NSE vuln scripts...${NC}"
    nmap -sV --script vuln --script-args vulns.showall "$target" > "$scan_file" 2>&1
    
    if [ -s "$scan_file" ]; then
        echo -e "${G}[✓] Vulnerability scan complete!${NC}"
        echo -e "${G}[✓] Results saved: $scan_file${NC}"
        log_message "Vulnerability scan completed on $target"
        
        generate_html_report "$target" "vulnerability_scan" "$scan_file"
        
        echo ""
        echo -e "${Y}===== CRITICAL VULNERABILITIES =====${NC}"
        grep -E "VULNERABLE|CVE-|HIGH|CRITICAL" "$scan_file" | head -10 || echo "No critical vulnerabilities found"
        
        return 0
    else
        echo -e "${R}[✗] Vulnerability scan failed!${NC}"
        log_message "Vulnerability scan failed on $target"
        return 1
    fi
}

